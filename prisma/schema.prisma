datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

// ---- Auth.js required models ----

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  currentLevel     CEFRLevel?
  currentObjective String?

  accounts      Account[]
  sessions      Session[]
  tracks        Track[]
  voiceSessions VoiceSession[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---- App models ----

enum CEFRLevel {
  A1
  A2
  B1
  B2
  C1
}

enum TrackStatus {
  ACTIVE
  COMPLETED
  PAUSED
}

enum LessonStatus {
  LOCKED
  AVAILABLE
  IN_PROGRESS
  COMPLETED
}

model Objective {
  id          String  @id @default(cuid())
  slug        String  @unique
  name        String
  description String
  icon        String
  tracks      Track[]
}

model Track {
  id          String      @id @default(cuid())
  userId      String
  objectiveId String
  level       CEFRLevel
  status      TrackStatus @default(ACTIVE)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  objective Objective @relation(fields: [objectiveId], references: [id])
  lessons   Lesson[]

  @@unique([userId, objectiveId, level])
}

model Lesson {
  id          String       @id @default(cuid())
  trackId     String
  title       String
  topic       String
  description String
  order       Int
  status      LessonStatus @default(LOCKED)
  completedAt DateTime?

  track         Track          @relation(fields: [trackId], references: [id], onDelete: Cascade)
  voiceSessions VoiceSession[]

  @@unique([trackId, order])
}

model VoiceSession {
  id        String    @id @default(cuid())
  lessonId  String
  userId    String
  startedAt DateTime  @default(now())
  endedAt   DateTime?
  duration  Int?

  summary       String? @db.Text
  feedback      String? @db.Text
  pronunciation Float?
  fluency       Float?

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}
